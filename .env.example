# Configuração do Banco de Dados
# Caminho absoluto para o arquivo do banco Access
DB_PATH=C:\inetpub\wwwroot\cadastro\db\cadastro.mdb

# String de conexão alternativa (se necessário)
# DB_CONNECTION_STRING=Provider=Microsoft.Jet.OLEDB.4.0;Data Source=C:\caminho\para\cadastro.mdb;

# Configurações do Sistema
SITE_TITLE=Sistema de Cadastro
MAX_RECORDS_PER_PAGE=50

# Configurações de Validação
CPF_REQUIRED=true
CEP_REQUIRED=true

# Configurações de Debug (true/false)
DEBUG_MODE=false
SHOW_SQL_ERRORS=false